    "start": "functions-framework --target=api --source=dist/index.js --signature-type=http"
  },
  "dependencies": {
    "@google-cloud/functions-framework": "^3.4.6",
    "cors": "^2.8.5",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.6.3"
  }
}
