{
  "name": "ai-email-summary-backend",
  "private": true,
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.11.1"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx watch index.ts",
